# Firebase Web SDK (frontend). Put real values in web/.env.local
VITE_FIREBASE_API_KEY=replace_with_new_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=ada-visions.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ada-visions
VITE_FIREBASE_STORAGE_BUCKET=ada-visions.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=replace_with_sender_id
VITE_FIREBASE_APP_ID=replace_with_app_id
VITE_FIREBASE_MEASUREMENT_ID=replace_with_measurement_id

# Optional: override local Ollama host/model for server-side AI endpoints
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:0.5b
